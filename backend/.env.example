# ── Graph DB ──────────────────────────────────────────────────────────────────
GRAPH_DB_PLUGIN=falkordb
FALKORDB_HOST=localhost
FALKORDB_PORT=6379

# ── PostgreSQL (contracts demo) ───────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=contracts
POSTGRES_USER=lattice
POSTGRES_PASSWORD=lattice123

# ── LLM ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-api-key-here

# ── Docker socket (macOS Docker Desktop) ─────────────────────────────────────
DOCKER_HOST=unix:///Users/<your-username>/.docker/run/docker.sock

# ── Seed on startup ───────────────────────────────────────────────────────────
SEED_ON_STARTUP=true
