# ── Graph DB ──────────────────────────────────────────────────────────────────
GRAPH_DB_PLUGIN=falkordb
FALKORDB_HOST=localhost
FALKORDB_PORT=6379

# ── PostgreSQL (structured contracts) ────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=contracts
POSTGRES_USER=lattice
POSTGRES_PASSWORD=lattice123

# ── MongoDB (unstructured legal documents) ────────────────────────────────────
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DB=contracts_docs

# ── LLM ───────────────────────────────────────────────────────────────────────
LLM_PROVIDER=openai
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o

# ── Docker socket (macOS Docker Desktop) ─────────────────────────────────────
DOCKER_HOST=unix:///Users/<your-username>/.docker/run/docker.sock

# ── Seed on startup ───────────────────────────────────────────────────────────
SEED_ON_STARTUP=true
